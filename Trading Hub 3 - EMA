    array.remove(ofZoneActive, i)
    array.remove(ofZoneMit, i)

// Pivot MỚI xác nhận vượt qua biên giữ của vùng OF => cấu trúc đã phủ nhận vùng, xoá.
// Khác với wick: râu nến chọc qua biên KHÔNG giết vùng (xem processOFZones), nhưng một
// swing ĐÃ XÁC NHẬN vượt đỉnh vùng bear / thủng đáy vùng bull thì vùng hết giá trị —
// tránh vùng cũ bị giá vượt mặt vẫn kéo dài mãi. Vùng mitigated (đã đóng băng) giữ nguyên.
invalidateOFByPivot(bool isHighPivot, float p) =>
    if array.size(ofZone) > 0
        for i = array.size(ofZone) - 1 to 0 by 1
            if not array.get(ofZoneMit, i)
                [t, b, l] = marginZone(array.get(ofZone, i))
                bool isBull = array.get(ofZoneIsBull, i)
                if (isHighPivot and not isBull and t < p) or (not isHighPivot and isBull and b > p)
                    removeOFZone(i)

// Đẩy thẳng 1 vùng OF mới (không qua kiểm tra chứa/nuốt của addOFZone).
pushOFZone(int left, float top, float bot, bool isBull) =>
    color col = isBull ? colorOFBull : colorOFBear
    array.push(ofZone, createOFBox(left, top, bot, col))
    array.push(ofLabel, label.new(left, top, "OF", xloc.bar_time, yloc.price, color = transp, textcolor = col, style = label.style_label_down, size = size.tiny))
    array.push(ofZoneBarIdx, bar_index)
    array.push(ofZoneIsBull, isBull)
    array.push(ofZoneActive, false)
    array.push(ofZoneMit, false)

addOFZone(int left, float top, float bot, bool isBull) =>
    // Chỉ xét chứa/nuốt với vùng CÒN SỐNG (chưa mitigated): vùng mitigated là lịch sử đã
    // đóng băng — không được chặn vùng mới tạo (từng làm mất OF hợp lệ vì một box xám cũ
    // hàng tháng trước vẫn nằm trong mảng), và cũng không bị vùng mới nuốt mất.
    bool contained = false
    if array.size(ofZone) > 0
        for i = array.size(ofZone) - 1 to 0 by 1
            if array.get(ofZoneIsBull, i) == isBull and not array.get(ofZoneMit, i)
                [t, b, l] = marginZone(array.get(ofZone, i))
                if top <= t and bot >= b
                    contained := true
                else if t <= top and b >= bot
                    removeOFZone(i)
    if not contained
        pushOFZone(left, top, bot, isBull)

processOFZones() =>
    if array.size(ofZone) > 0
        for i = array.size(ofZone) - 1 to 0 by 1
            box zone = array.get(ofZone, i)
            [t, b, l] = marginZone(zone)
            bool isBull = array.get(ofZoneIsBull, i)
            bool active = array.get(ofZoneActive, i)
            bool expired = bar_index - array.get(ofZoneBarIdx, i) > 1999
            bool matured = bar_index - array.get(ofZoneBarIdx, i) >= minOFAge

            if not active
                // Pha 1: box vừa tạo, giá thường còn nằm trong vùng => GIỮ NGUYÊN MÀU,
                // chỉ kích hoạt khi cả cây nến đã RỜI HẲN khỏi vùng.
                //   bull/demand: cả nến nằm trên đỉnh vùng (low > t)
                //   bear/supply: cả nến nằm dưới đáy vùng (high < b)
                if (isBull and low > t) or (not isBull and high < b)
                    array.set(ofZoneActive, i, true)
                // Hỏng trước khi kích hoạt: đóng cửa xuyên biên giữ, hoặc hết hạn => xoá
                if expired or (isBull and close < b) or (not isBull and close > t)
                    removeOFZone(i)
            else
                // Pha 2 (đã active): mitigated / xoá. ĐÃ BỎ breaker flip: box bị phá xuyên không
                // lật màu thành vùng ngược hướng nữa — vùng lật giữ biên độ của chân hồi CŨ nên
                // không phải OF thật của hướng mới; chân hồi mới sẽ tự tạo OF riêng (pullback/CHOCH).
                // Mitigated: giá quay lại và ĐÓNG CỬA bên trong vùng => tô xám, dừng kéo dài.
                // Wick chỉ quét râu vào vùng rồi đóng ngoài => BỎ QUA (vùng vẫn active, tiếp tục
                // kéo dài) — tránh box bị đông cứng sớm bởi một cú retest râu nến rồi "biến mất".
                // CHỈ tính khi vùng đã đủ tuổi minOFAge (đang hiển thị) — cú chạm khi vùng còn non
                // (đang ẩn) là phản ứng của chính con sóng tạo vùng, cũng bỏ qua.
                if matured and ((not isBull and close >= b and close < t) or (isBull and close <= t and close > b))
                    box.set_right(zone, time)
                    box.set_extend(zone, extend.none)
                    array.set(ofZoneMit, i, true)

                // Xóa khi nến ĐÓNG CỬA xuyên qua biên giữ hoặc hết hạn (vùng gốc bị phá cũng xóa
                // ở đây, chỉ giữ vùng lật breaker). KHÔNG xoá theo wick: râu nến chọc qua biên chỉ
                // là quét thanh khoản (sweep) — nến đóng lại trong/ngoài vùng thì vùng vẫn còn
                // giá trị. Trước đây xoá theo wick khiến rất nhiều OF bị giết oan chỉ vì một râu
                // chọc nhẹ vài tick qua đáy/đỉnh vùng.
                if expired or (not isBull and close > t) or (isBull and close < b)
                    removeOFZone(i)

    // HIỂN THỊ — chỉ tính ở nến cuối (màu box là trạng thái sau cùng nên không cần set từng nến):
    //  - vùng non hơn minOFAge: ẩn
    //  - vùng xám (mitigated): chỉ hiện khi bật showMitOF (lịch sử, không giao dịch được nữa)
    //  - vùng active: mỗi chiều bull/bear chỉ hiện maxOFShow vùng GẦN GIÁ nhất; vùng xa tự ẩn,
    //    khi giá quay lại gần thì tự hiện. Lifecycle vẫn chạy bình thường cho vùng đang ẩn.
    if barstate.islast and array.size(ofZone) > 0
        int zCnt = array.size(ofZone)
        distArr = array.new_float(zCnt, 0.0)
        for i = 0 to zCnt - 1
            [t, b, l] = marginZone(array.get(ofZone, i))
            array.set(distArr, i, close > t ? close - t : close < b ? b - close : 0.0)
        for i = zCnt - 1 to 0 by 1
            box zone = array.get(ofZone, i)
            bool isBull = array.get(ofZoneIsBull, i)
            bool isMit = array.get(ofZoneMit, i)
            // Vùng mitigated mà giá HIỆN ĐANG nằm trong (đang khai thác, chưa phá qua biên giữ)
            // vẫn hiện với MÀU GỐC: nếu để xám/ẩn theo showMitOF thì vùng biến mất đúng lúc giá
            // đang phản ứng với nó. Chỉ ưu ái vùng đang khai thác; mitigated khác vẫn ẩn như cũ.
            bool ofExploit = false
            if isMit
                [t, b, l] = marginZone(zone)
                ofExploit := close <= t and close >= b
            bool visible = bar_index - array.get(ofZoneBarIdx, i) >= minOFAge
            if visible and isMit
                visible := ofExploit or showMitOF
            if visible and not isMit
                // xếp hạng theo khoảng cách tới giá trong các vùng active cùng chiều, đã đủ tuổi
                int nearer = 0
                float di = array.get(distArr, i)
                for j = 0 to zCnt - 1
                    if j != i and array.get(ofZoneIsBull, j) == isBull and not array.get(ofZoneMit, j) and bar_index - array.get(ofZoneBarIdx, j) >= minOFAge
                        float dj = array.get(distArr, j)
                        if dj < di or (dj == di and j > i)
                            nearer += 1
                visible := nearer < maxOFShow
            color col = isMit and not ofExploit ? colorMitigated : isBull ? colorOFBull : colorOFBear
            color shownCol = visible ? col : color.new(col, 100)
            box.set_bgcolor(zone, shownCol)
            box.set_border_color(zone, shownCol)
            label.set_textcolor(array.get(ofLabel, i), shownCol)

addLastPullbackOF(bool isBull) =>
    // OF tại CHOCH luôn được vẽ, KHÔNG qua bộ lọc HH/LL: CHOCH đã tự xác nhận đảo chiều, nên
    // chân sóng cuối đâm vào đáy/đỉnh đảo chiều CHÍNH LÀ vùng OF hợp lệ (nếu lọc HH/LL ở đây
    // thì OF đảo chiều gần như không bao giờ được vẽ vì đáy trước CHOCH-up thường là LL và
    // đỉnh trước CHOCH-down thường là HH). Bộ lọc HH/LL chỉ dành cho pullback giữa trend.
    // Vùng OF = đúng CHÂN HỒI kết thúc tại pivot neo: bear = đáy TRƯỚC đỉnh LH -> đỉnh LH,
    // bull = đỉnh TRƯỚC đáy HL -> đáy HL. Không ghép với pivot mới hình thành SAU pivot neo
    // (đáy/đỉnh của chân đẩy) vì sẽ kéo box phủ cả chân impulse thay vì chỉ chân pullback.
    if showOF
        if isBull
            float ofB = getNLastValue(puLow, 1)
            int ofBBar = getNLastValue(puLBar, 1)
            if not na(ofB)
                [ofT, ofTBar] = findPivotBefore(puHigh, puHBar, ofBBar)
                if not na(ofT)
                    addOFZone(math.min(ofTBar, ofBBar), ofT, ofB, true)
        else
            float ofT = getNLastValue(puHigh, 1)
            int ofTBar = getNLastValue(puHBar, 1)
            if not na(ofT)
                [ofB, ofBBar] = findPivotBefore(puLow, puLBar, ofTBar)
                if not na(ofB)
                    addOFZone(math.min(ofTBar, ofBBar), ofT, ofB, false)

scob(zones, isSupply) =>
    [topZone, botZone, leftZone] = marginZone(getNLastValue(zones, 1))

    if not isb[1]
        if not isSupply and low[1] < low[2] and low[1] < low and close > high[1] and low[1] < topZone and low[1] > botZone
            scobUp
        else if isSupply and high[1] > high[2] and high[1] > high and close < low[1] and high[1] < topZone and high[1] > botZone
            scobDn
        else
            na
//#endregion

//#region OF 4H functions (bản sao độc lập của các hàm quản lý vùng OF, dùng riêng cho engine 4H)
removeOFZone4(int i) =>
    box.delete(array.get(ofZone4, i))
    label.delete(array.get(ofLabel4, i))
    array.remove(ofZone4, i)
    array.remove(ofLabel4, i)
    array.remove(ofZoneBarIdx4, i)
    array.remove(ofZoneIsBull4, i)
    array.remove(ofZoneActive4, i)
    array.remove(ofZoneMit4, i)

invalidateOFByPivot4(bool isHighPivot, float p) =>
    if array.size(ofZone4) > 0
        for i = array.size(ofZone4) - 1 to 0 by 1
            if not array.get(ofZoneMit4, i)
                [t, b, l] = marginZone(array.get(ofZone4, i))
                bool isBull = array.get(ofZoneIsBull4, i)
                if (isHighPivot and not isBull and t < p) or (not isHighPivot and isBull and b > p)
                    removeOFZone4(i)

pushOFZone4(int left, float top, float bot, bool isBull) =>
    color col = isBull ? colorOF4Bull : colorOF4Bear
    array.push(ofZone4, createOFBox(left, top, bot, col))
    array.push(ofLabel4, label.new(left, top, "OF 4H", xloc.bar_time, yloc.price, color = transp, textcolor = col, style = label.style_label_down, size = size.tiny))
    array.push(ofZoneBarIdx4, h4barCnt)
    array.push(ofZoneIsBull4, isBull)
    array.push(ofZoneActive4, false)
    array.push(ofZoneMit4, false)

addOFZone4(int left, float top, float bot, bool isBull) =>
    bool contained = false
    if array.size(ofZone4) > 0
        for i = array.size(ofZone4) - 1 to 0 by 1
            if array.get(ofZoneIsBull4, i) == isBull and not array.get(ofZoneMit4, i)
                [t, b, l] = marginZone(array.get(ofZone4, i))
                if top <= t and bot >= b
                    contained := true
                else if t <= top and b >= bot
                    removeOFZone4(i)
    if not contained
        pushOFZone4(left, top, bot, isBull)

// Lifecycle vùng OF 4H — chạy MỖI KHI ĐÓNG 1 NẾN 4H với giá 4H (hh/ll/cc), KHÔNG chạy theo
// nến 15m: vùng 4H rộng theo biên độ chân hồi 4H, nếu xét close 15m thì chỉ vài giờ là có
// nến 15m đóng trong vùng -> mitigated/xoá oan hàng loạt, không còn vùng nào hiển thị.
// Xét theo close 4H thì hành vi giống hệt khi xem vùng đó trên chart 4H.
lifecycleOFZones4(float hh, float ll, float cc) =>
    if array.size(ofZone4) > 0
        for i = array.size(ofZone4) - 1 to 0 by 1
            box zone = array.get(ofZone4, i)
            [t, b, l] = marginZone(zone)
            bool isBull = array.get(ofZoneIsBull4, i)
            bool active = array.get(ofZoneActive4, i)
            bool expired = h4barCnt - array.get(ofZoneBarIdx4, i) > 1999
            bool matured = h4barCnt - array.get(ofZoneBarIdx4, i) >= minOFAge

            if not active
                if (isBull and ll > t) or (not isBull and hh < b)
                    array.set(ofZoneActive4, i, true)
                if expired or (isBull and cc < b) or (not isBull and cc > t)
                    removeOFZone4(i)
            else
                if matured and ((not isBull and cc >= b and cc < t) or (isBull and cc <= t and cc > b))
                    box.set_right(zone, time)
                    box.set_extend(zone, extend.none)
                    array.set(ofZoneMit4, i, true)

                if expired or (not isBull and cc > t) or (isBull and cc < b)
                    removeOFZone4(i)

visibilityOFZones4() =>
