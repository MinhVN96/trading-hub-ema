        for i = zCnt - 1 to 0 by 1
            box zone = array.get(ofZone4, i)
            bool isBull = array.get(ofZoneIsBull4, i)
            bool isMit = array.get(ofZoneMit4, i)
            // Vùng mitigated đang được giá khai thác (giá nằm trong vùng, chưa phá qua) vẫn
            // hiện màu gốc — cùng logic với processOFZones, xem giải thích ở đó.
            bool ofExploit = false
            if isMit
                [t, b, l] = marginZone(zone)
                ofExploit := close <= t and close >= b
            bool visible = h4barCnt - array.get(ofZoneBarIdx4, i) >= minOFAge
            if visible and isMit
                visible := ofExploit or showMitOF
            if visible and not isMit
                int nearer = 0
                float di = array.get(distArr, i)
                for j = 0 to zCnt - 1
                    if j != i and array.get(ofZoneIsBull4, j) == isBull and not array.get(ofZoneMit4, j) and h4barCnt - array.get(ofZoneBarIdx4, j) >= minOFAge
                        float dj = array.get(distArr, j)
                        if dj < di or (dj == di and j > i)
                            nearer += 1
                visible := nearer < maxOFShow
            color col = isMit and not ofExploit ? colorMitigated : isBull ? colorOF4Bull : colorOF4Bear
            color shownCol = visible ? col : color.new(col, 100)
            box.set_bgcolor(zone, shownCol)
            box.set_border_color(zone, shownCol)
            label.set_textcolor(array.get(ofLabel4, i), shownCol)

addLastPullbackOF4(bool isBull) =>
    if isBull
        float ofB = getNLastValue(puLow4, 1)
        int ofBBar = getNLastValue(puLBar4, 1)
        if not na(ofB)
            [ofT, ofTBar] = findPivotBefore(puHigh4, puHBar4, ofBBar)
            if not na(ofT)
                addOFZone4(math.min(ofTBar, ofBBar), ofT, ofB, true)
    else
        float ofT = getNLastValue(puHigh4, 1)
        int ofTBar = getNLastValue(puHBar4, 1)
        if not na(ofT)
            [ofB, ofBBar] = findPivotBefore(puLow4, puLBar4, ofTBar)
            if not na(ofB)
                addOFZone4(math.min(ofTBar, ofBBar), ofT, ofB, false)
//#endregion

//#region Pullback
if high >= top and low <= bot //notrend
    if not na(mnStrc)
        prevMnStrc := mnStrc ? true : false
    top_ := prevMnStrc ? top : top_
    bot_ := prevMnStrc ? bot_ : bot
    bar_ := bar
    top  := high
    bot  := low
    bar  := time
    mnStrc := na

if high >= top and low > bot //uptrend
    if prevMnStrc and na(mnStrc)
        array.push(puHBar, bar_)
        array.push(puHigh, top_)
        array.push(puLBar, bar)
        array.push(puLow, bot)
        invalidateOFByPivot(true, top_)
        invalidateOFByPivot(false, bot)
        drawPullback(bar_, top_, true)
        drawPullback(bar, bot, false)
        addZigPoint(bar_, top_)
        addZigPoint(bar, bot)
        lastPivotHighIsHH := na(prevPivotHigh) or top_ >= prevPivotHigh
        lastPivotLowIsLL  := na(prevPivotLow) or bot <= prevPivotLow
        if showOF and (not lastPivotLowIsLL or isCocUp)
            addOFZone(bar_, top_, bot, true)
        prevPivotHigh := top_
        prevPivotLow  := bot
    else if (not prevMnStrc and na(mnStrc)) or not mnStrc
        array.push(puLBar, bar)
        array.push(puLow, bot)
        invalidateOFByPivot(false, bot)
        drawPullback(bar, bot, false)
        addZigPoint(bar, bot)
        lastPivotLowIsLL := na(prevPivotLow) or bot <= prevPivotLow
        if showOF and (not lastPivotLowIsLL or isCocUp)
            [ofTop, ofTopBar] = findPivotBefore(puHigh, puHBar, bar) //đỉnh phải có TRƯỚC đáy vừa xác nhận
            if na(ofTop)
                ofTop := top_
                ofTopBar := bar_
            addOFZone(math.min(ofTopBar, bar), ofTop, bot, true)
        prevPivotLow := bot

    top := high
    bot := low
    bar := time
    prevMnStrc := na
    mnStrc := true

if high < top and low <= bot //downtrend
    if not prevMnStrc and na(mnStrc)
        array.push(puHBar, bar)
        array.push(puHigh, top)
        array.push(puLBar, bar_)
        array.push(puLow, bot_)
        invalidateOFByPivot(true, top)
        invalidateOFByPivot(false, bot_)
        drawPullback(bar, top, true)
        drawPullback(bar_, bot_, false)
        addZigPoint(bar_, bot_)
        addZigPoint(bar, top)
        lastPivotHighIsHH := na(prevPivotHigh) or top >= prevPivotHigh
        lastPivotLowIsLL  := na(prevPivotLow) or bot_ <= prevPivotLow
        if showOF and (not lastPivotHighIsHH or isCocDn)
            addOFZone(bar_, top, bot_, false)
        prevPivotHigh := top
        prevPivotLow  := bot_
    else if (prevMnStrc and na(mnStrc)) or mnStrc
        array.push(puHBar, bar)
        array.push(puHigh, top)
        invalidateOFByPivot(true, top)
        drawPullback(bar, top, true)
        addZigPoint(bar, top)
        lastPivotHighIsHH := na(prevPivotHigh) or top >= prevPivotHigh
        if showOF and (not lastPivotHighIsHH or isCocDn)
            [ofBot, ofBotBar] = findPivotBefore(puLow, puLBar, bar) //đáy phải có TRƯỚC đỉnh vừa xác nhận
            if na(ofBot)
                ofBot := bot_
                ofBotBar := bar_
            addOFZone(math.min(ofBotBar, bar), top, ofBot, false)
        prevPivotHigh := top

    top := high
    bot := low
    bar := time
    prevMnStrc := na
    mnStrc := false

//#region update IDM
if high >= H
    H := high
    HBar := time
    L_lastHH := low
    idmLow := getNLastValue(puLow, 1)
    idmLBar := getNLastValue(puLBar, 1)

if low <= L
    L := low
    LBar := time
    H_lastLL := high
    idmHigh := getNLastValue(puHigh, 1)
    idmHBar := getNLastValue(puHBar, 1)

//#endregion

// #region structure mapping
// Check for ChoCh — đặt TRƯỚC khối IDM để tránh dùng lastH/lastL vừa bị
// khối IDM ghi đè trong cùng 1 bar (gây CHOCH bắn sai ngay sát IDM)
if not findIDM and isCocDn and high > lastH
    if structure_type == "Choch without IDM" and idmHigh == lastH and close > idmHigh
        removeIdm()
    if close > lastH
        drawStructure(CHOCH_TEXT, true) //Confirm CocUp
        addLastPullbackOF(true)
        findIDM := true
        isBosUp := true
        isCocUp := true
        isBosDn := false
        isCocDn := false
        isPrevBos := false
        L_lastL := getNLastValue(arrLastL, 1)

if not findIDM and isCocUp and low < lastL
    if structure_type == "Choch without IDM" and idmLow == lastL and close < idmLow
        removeIdm()
    if close < lastL
        drawStructure(CHOCH_TEXT, false) //Confirm CocDn
        addLastPullbackOF(false)
        findIDM := true
        isBosUp := false
        isCocUp := false
        isBosDn := true
        isCocDn := true
        isPrevBos := false
        H_lastH := getNLastValue(arrLastH, 1)

// Check for IDM
if findIDM and isCocUp
    if low < idmLow
        findIDM := false
        isBosUp := false
        L := low
        LBar := time
        if structure_type == "Choch with IDM" and idmLow == lastL
            if isPrevBos
                fixStrcAfterBos()
                lastL := getNLastValue(arrLastL, 1)
                lastLBar := getNLastValue(arrLastLBar, 1)
                lastH := H
                lastHBar := HBar
                drawIDM(true)
                // drawHL(true, 'HH')
                updateLastH()
                updateLastL()
                H_lastH := getNLastValue(arrLastH, 1)
            else
                fixStrcAfterChoch()
                isCocUp := false
                isCocDn := true
        else
            lastH := H
            lastHBar := HBar
            drawIDM(true)
            // drawHL(true, 'HH')
            updateLastH()
            updateLastL()
            H_lastH := getNLastValue(arrLastH, 1)


if findIDM and isCocDn and isBosDn
    if high > idmHigh
        findIDM := false
        isBosDn := false
        H := high
        HBar := time
        if structure_type == "Choch with IDM" and idmHigh == lastH
            if isPrevBos
                fixStrcAfterBos()
                lastH := getNLastValue(arrLastH, 1)
                lastHBar := getNLastValue(arrLastHBar, 1)
                lastL := L
                lastLBar := LBar
                drawIDM(false)
                // drawHL(false, 'LL')
                updateLastH()
                updateLastL()
                L_lastL := getNLastValue(arrLastL, 1)
            else
                fixStrcAfterChoch()
                isCocUp := true
                isCocDn := false
        else
            lastL := L
            lastLBar := LBar
            drawIDM(false)
            // drawHL(false, 'LL')
            updateLastH()
            updateLastL()
            L_lastL := getNLastValue(arrLastL, 1)


//Check for BoS
if not findIDM and not isBosUp and isCocUp
    if high > lastH
        if close > lastH
            drawStructure(BOS_TEXT, true) //Confirm BosUp
            findIDM := true
            isBosUp := true
            isCocUp := true
            isBosDn := false
            isCocDn := false
            isPrevBos := true
            // drawHL(false, 'HL')
            lastL := L
            lastLBar := LBar
            L_lastL := L

if not findIDM and not isBosDn and isCocDn
    if low < lastL
        if close < lastL
            drawStructure(BOS_TEXT, false)   //Confirm BosDn
            findIDM := true
            isBosUp := false
            isCocUp := false
            isBosDn := true
            isCocDn := true
            isPrevBos := true
            // drawHL(true, 'LH')
            lastH := H
            lastHBar := HBar
            H_lastH := H
//#endregion

//#trigger update High and Low
// Trong phase tìm IDM (findIDM=true): cả hai cập nhật để track HH/LL hiện tại
// Trong phase tìm BOS/CHOCH (findIDM=false): chỉ cập nhật chiều ngược xu hướng
//   - Bullish: lastH cố định (mức BOS), lastL bám theo swing pullback gần nhất (HL cho CHOCH)
//   - Bearish: lastL cố định (mức BOS), lastH bám theo swing pullback gần nhất (LH cho CHOCH)
// Dùng puHigh/puLow (đỉnh/đáy pullback đã xác nhận) thay vì running max/min của high/low,
// để lastH/lastL giữ cố định tại swing thực sự cho đến khi có pivot mới, tránh bị "ratchet"
// theo từng cây nến khiến CHOCH không bao giờ thoả close > lastH / close < lastL.
// Chỉ cho phép lastH dịch XUỐNG (Lower High mới thấp hơn) và lastL dịch LÊN (Higher Low mới
// cao hơn) — đúng chiều của xu hướng hiện tại — để tránh CHOCH bắn liên tục theo từng pullback
// nhỏ khi các đỉnh/đáy hồi chỉ nhích nhẹ ngược chiều xu hướng.
if findIDM
    if high > lastH
        lastH := high
        lastHBar := time
    if low < lastL
        lastL := low
        lastLBar := time
else
    if isCocUp
        float newLastL = getNLastValue(puLow, 1)
        if not na(newLastL) and newLastL > lastL
            lastL := newLastL
            lastLBar := getNLastValue(puLBar, 1)
    else if isCocDn
        float newLastH = getNLastValue(puHigh, 1)
        if not na(newLastH) and newLastH < lastH
            lastH := newLastH
            lastHBar := getNLastValue(puHBar, 1)

//#endregion

//#region OF 4H engine (bản sao độc lập, chạy trên dữ liệu 4H đã đóng nến qua request.security,
// chỉ để sinh vùng OF của khung 4H khi chart đang ở 15m — không vẽ BOS/CHoCH/IDM/zigzag)
is15m = timeframe.period == "15"
f_htf(src) => request.security(syminfo.tickerid, "240", src[1], lookahead = barmerge.lookahead_off)
h4 = f_htf(high)
l4 = f_htf(low)
c4 = f_htf(close)
t4 = f_htf(time)
newH4bar = ta.change(t4) != 0

if show4hOF and is15m and newH4bar and not na(t4)
    h4barCnt += 1
    if not h4Started
        H4 := h4
        L4 := l4
        HBar4 := t4
        LBar4 := t4
        lastH4 := h4
        lastL4 := l4
        lastHBar4 := t4
        lastLBar4 := t4
        idmLow4 := l4
        idmHigh4 := h4
        idmLBar4 := t4
        idmHBar4 := t4
        top4 := h4
        bot4 := l4
        top4_ := h4
        bot4_ := l4
        bar4 := t4
        bar4_ := t4
        h4Started := true
    else
        //Pullback
        if h4 >= top4 and l4 <= bot4 //notrend
            if not na(mnStrc4)
                prevMnStrc4 := mnStrc4 ? true : false
            top4_ := prevMnStrc4 ? top4 : top4_
            bot4_ := prevMnStrc4 ? bot4_ : bot4
            bar4_ := bar4
            top4  := h4
            bot4  := l4
            bar4  := t4
            mnStrc4 := na

        if h4 >= top4 and l4 > bot4 //uptrend
            if prevMnStrc4 and na(mnStrc4)
                array.push(puHBar4, bar4_)
                array.push(puHigh4, top4_)
                array.push(puLBar4, bar4)
                array.push(puLow4, bot4)
                invalidateOFByPivot4(true, top4_)
                invalidateOFByPivot4(false, bot4)
                lastPivotHighIsHH4 := na(prevPivotHigh4) or top4_ >= prevPivotHigh4
                lastPivotLowIsLL4  := na(prevPivotLow4) or bot4 <= prevPivotLow4
                if not lastPivotLowIsLL4 or isCocUp4
                    addOFZone4(bar4_, top4_, bot4, true)
                prevPivotHigh4 := top4_
                prevPivotLow4  := bot4
            else if (not prevMnStrc4 and na(mnStrc4)) or not mnStrc4
                array.push(puLBar4, bar4)
                array.push(puLow4, bot4)
                invalidateOFByPivot4(false, bot4)
                lastPivotLowIsLL4 := na(prevPivotLow4) or bot4 <= prevPivotLow4
                if not lastPivotLowIsLL4 or isCocUp4
                    [ofTop, ofTopBar] = findPivotBefore(puHigh4, puHBar4, bar4)
                    if na(ofTop)
                        ofTop := top4_
                        ofTopBar := bar4_
                    addOFZone4(math.min(ofTopBar, bar4), ofTop, bot4, true)
                prevPivotLow4 := bot4

            top4 := h4
            bot4 := l4
            bar4 := t4
            prevMnStrc4 := na
            mnStrc4 := true

        if h4 < top4 and l4 <= bot4 //downtrend
            if not prevMnStrc4 and na(mnStrc4)
                array.push(puHBar4, bar4)
                array.push(puHigh4, top4)
                array.push(puLBar4, bar4_)
                array.push(puLow4, bot4_)
                invalidateOFByPivot4(true, top4)
                invalidateOFByPivot4(false, bot4_)
                lastPivotHighIsHH4 := na(prevPivotHigh4) or top4 >= prevPivotHigh4
                lastPivotLowIsLL4  := na(prevPivotLow4) or bot4_ <= prevPivotLow4
                if not lastPivotHighIsHH4 or isCocDn4
                    addOFZone4(bar4_, top4, bot4_, false)
                prevPivotHigh4 := top4
                prevPivotLow4  := bot4_
            else if (prevMnStrc4 and na(mnStrc4)) or mnStrc4
                array.push(puHBar4, bar4)
                array.push(puHigh4, top4)
                invalidateOFByPivot4(true, top4)
                lastPivotHighIsHH4 := na(prevPivotHigh4) or top4 >= prevPivotHigh4
                if not lastPivotHighIsHH4 or isCocDn4
                    [ofBot, ofBotBar] = findPivotBefore(puLow4, puLBar4, bar4)
                    if na(ofBot)
                        ofBot := bot4_
                        ofBotBar := bar4_
                    addOFZone4(math.min(ofBotBar, bar4), top4, ofBot, false)
                prevPivotHigh4 := top4

            top4 := h4
            bot4 := l4
            bar4 := t4
            prevMnStrc4 := na
            mnStrc4 := false

        //update IDM
        if h4 >= H4
            H4 := h4
            HBar4 := t4
            idmLow4 := getNLastValue(puLow4, 1)
            idmLBar4 := getNLastValue(puLBar4, 1)

        if l4 <= L4
            L4 := l4
            LBar4 := t4
            idmHigh4 := getNLastValue(puHigh4, 1)
            idmHBar4 := getNLastValue(puHBar4, 1)

        //structure mapping: CHoCH -> IDM -> BOS (chỉ side-effect phi-visual, không vẽ)
        if not findIDM4 and isCocDn4 and h4 > lastH4
            if c4 > lastH4 //Confirm CocUp
                addLastPullbackOF4(true)
                findIDM4 := true
                isBosUp4 := true
                isCocUp4 := true
                isBosDn4 := false
                isCocDn4 := false
                isPrevBos4 := false

        if not findIDM4 and isCocUp4 and l4 < lastL4
            if c4 < lastL4 //Confirm CocDn
                addLastPullbackOF4(false)
                findIDM4 := true
                isBosUp4 := false
                isCocUp4 := false
                isBosDn4 := true
                isCocDn4 := true
                isPrevBos4 := false

        if findIDM4 and isCocUp4
            if l4 < idmLow4
                findIDM4 := false
                isBosUp4 := false
                L4 := l4
                LBar4 := t4
                if structure_type == "Choch with IDM" and idmLow4 == lastL4
                    if isPrevBos4
                        lastL4 := getNLastValue(arrLastL4, 1)
                        lastLBar4 := getNLastValue(arrLastLBar4, 1)
                        lastH4 := H4
                        lastHBar4 := HBar4
                        array.clear(puLow4)
                        array.clear(puLBar4)
                        array.push(arrLastH4, lastH4)
                        array.push(arrLastHBar4, lastHBar4)
                        array.push(arrLastL4, lastL4)
                        array.push(arrLastLBar4, lastLBar4)
                    else
                        isCocUp4 := false
                        isCocDn4 := true
                else
                    lastH4 := H4
                    lastHBar4 := HBar4
                    array.clear(puLow4)
                    array.clear(puLBar4)
                    array.push(arrLastH4, lastH4)
                    array.push(arrLastHBar4, lastHBar4)
                    array.push(arrLastL4, lastL4)
                    array.push(arrLastLBar4, lastLBar4)

        if findIDM4 and isCocDn4 and isBosDn4
            if h4 > idmHigh4
                findIDM4 := false
                isBosDn4 := false
                H4 := h4
                HBar4 := t4
                if structure_type == "Choch with IDM" and idmHigh4 == lastH4
                    if isPrevBos4
                        lastH4 := getNLastValue(arrLastH4, 1)
                        lastHBar4 := getNLastValue(arrLastHBar4, 1)
                        lastL4 := L4
                        lastLBar4 := LBar4
                        array.clear(puHigh4)
                        array.clear(puHBar4)
                        array.push(arrLastH4, lastH4)
                        array.push(arrLastHBar4, lastHBar4)
                        array.push(arrLastL4, lastL4)
                        array.push(arrLastLBar4, lastLBar4)
                    else
                        isCocUp4 := true
                        isCocDn4 := false
                else
                    lastL4 := L4
                    lastLBar4 := LBar4
                    array.clear(puHigh4)
                    array.clear(puHBar4)
                    array.push(arrLastH4, lastH4)
                    array.push(arrLastHBar4, lastHBar4)
                    array.push(arrLastL4, lastL4)
                    array.push(arrLastLBar4, lastLBar4)

        //Check for BoS
        if not findIDM4 and not isBosUp4 and isCocUp4
            if h4 > lastH4
                if c4 > lastH4 //Confirm BosUp
                    findIDM4 := true
                    isBosUp4 := true
                    isCocUp4 := true
                    isBosDn4 := false
                    isCocDn4 := false
                    isPrevBos4 := true
                    lastL4 := L4
                    lastLBar4 := LBar4

        if not findIDM4 and not isBosDn4 and isCocDn4
            if l4 < lastL4
                if c4 < lastL4 //Confirm BosDn
                    findIDM4 := true
                    isBosUp4 := false
                    isCocUp4 := false
                    isBosDn4 := true
                    isCocDn4 := true
                    isPrevBos4 := true
                    lastH4 := H4
                    lastHBar4 := HBar4

        //trigger update High/Low
        if findIDM4
            if h4 > lastH4
                lastH4 := h4
                lastHBar4 := t4
            if l4 < lastL4
                lastL4 := l4
                lastLBar4 := t4
        else
            if isCocUp4
                float newLastL4 = getNLastValue(puLow4, 1)
                if not na(newLastL4) and newLastL4 > lastL4
                    lastL4 := newLastL4
                    lastLBar4 := getNLastValue(puLBar4, 1)
            else if isCocDn4
                float newLastH4 = getNLastValue(puHigh4, 1)
                if not na(newLastH4) and newLastH4 < lastH4
                    lastH4 := newLastH4
                    lastHBar4 := getNLastValue(puHBar4, 1)

        //lifecycle vùng OF 4H — xét theo chính nến 4H vừa đóng
        lifecycleOFZones4(h4, l4, c4)
//#endregion


if showPOI
    if not isSweepOBS
        high_MOBS := high[3]
        low_MOBS := low[3]
        current_OBS := time[3]
        if high_MOBS > high[4] and high_MOBS > high[2]
            isSweepOBS := true
    else
        if low_MOBS > high[1]
            handleZone(supplyZone, current_OBS, high_MOBS, low_MOBS, colorSupply)
            isSweepOBS := false
        else
            if poi_type == "Mother Bar" and isb[2]
                high_MOBS := math.max(high_MOBS,motherHigh[2])
                low_MOBS := math.min(low_MOBS,motherLow[2])
                current_OBS := math.min(current_OBS,motherBar)
            else
                high_MOBS := high[2]
                low_MOBS := low[2]
                current_OBS := time[2]

    if not isSweepOBD
        low_MOBD := low[3]
        high_MOBD := high[3]
        current_OBD := time[3]
        if low_MOBD < low[4] and low_MOBD < low[2]
            isSweepOBD := true
    else
        if high_MOBD < low[1]
            handleZone(demandZone, current_OBD, high_MOBD, low_MOBD, colorDemand)
            isSweepOBD := false
        else
            if poi_type == "Mother Bar" and isb[2]
                high_MOBD := math.max(high_MOBD,motherHigh[2])
                low_MOBD := math.min(low_MOBD,motherLow[2])
                current_OBD := math.min(current_OBD,motherBar)
            else
                high_MOBD := high[2]
                low_MOBD := low[2]
                current_OBD := time[2]
//#endregion

//#region run function
barcolor(showSCOB ? scob(supplyZone, true) : na, -1)
barcolor(showSCOB ? scob(demandZone, false) : na, -1)
processZones(supplyZone, true)
processZones(demandZone, false)
processOFZones()
if show4hOF and is15m
    visibilityOFZones4()
processZigLines()
drawLiveStrc(showliveIDM and findIDM, isCocUp, colorIDM, colorIDM, IDM_TEXT, lengIDM)
drawLiveStrc(showliveChoch, not isCocUp, bull, bear, CHOCH_TEXT, lengChoch)
drawLiveStrc(showliveBOS and not findIDM, isCocUp, bull, bear, BOS_TEXT, lengBos)
//#endregion

shortest = ta.ema(close, 20)
short     = ta.ema(close, 50)
longer    = ta.ema(close, 100)
longest   = ta.ema(close, 200)

plot(showEMA20  ? shortest : na, color = colorEMA20,  title = "EMA 20")
plot(showEMA50  ? short    : na, color = colorEMA50,  title = "EMA 50")
plot(showEMA100 ? longer   : na, color = colorEMA100, title = "EMA 100")
plot(showEMA200 ? longest  : na, color = colorEMA200, title = "EMA 200")

//#region LuxAlgo - Market Structure with Inducements & Sweeps
// Nguồn: © LuxAlgo (CC BY-NC-SA 4.0). Module độc lập, bật/tắt bằng lxEnable.
// Dùng thuật toán swing riêng (ta.highest/lowest) — KHÔNG ảnh hưởng cấu trúc/OF của Trading Hub.
n = bar_index

lxSwings(lkbk) =>
    var os = 0
    var int topx = na
    var int btmx = na

    upper = ta.highest(lkbk)
    lower = ta.lowest(lkbk)

    os := high[lkbk] > upper ? 0 : low[lkbk] < lower ? 1 : os[1]

    top = os == 0 and os[1] != 0 ? high[lkbk] : na
    topx := os == 0 and os[1] != 0 ? n[lkbk] : topx

    btm = os == 1 and os[1] != 1 ? low[lkbk] : na
    btmx := os == 1 and os[1] != 1 ? n[lkbk] : btmx

    [top, topx, btm, btmx]

[lxTop, topx, btm, btmx] = lxSwings(chochLen)
[stop, stopx, sbtm, sbtmx] = lxSwings(shortLen)

var os = 0
var top_crossed = false
var btm_crossed = false

var float max = na
var float min = na

var int max_x1 = na
var int min_x1 = na

var float topy = na
var float btmy = na
var stop_crossed = false
var sbtm_crossed = false

//CHoCH Detection
if lxTop
    topy := lxTop
    top_crossed := false
if btm
    btmy := btm
    btm_crossed := false

//Test for CHoCH
if close > topy and not top_crossed
    os := 1
    top_crossed := true
if close < btmy and not btm_crossed
    os := 0
    btm_crossed := true

//Display CHoCH
if os != os[1]
    max := high
    min := low
    max_x1 := n
    min_x1 := n
    stop_crossed := false
    sbtm_crossed := false

    if os == 1 and lxEnable and lxShowChoch
        line.new(topx, topy, n, topy, color = bullCss, style = line.style_dashed)
        label.new(int(math.avg(n, topx)), topy, 'CHoCH', color = color(na), style = label.style_label_down, textcolor = bullCss, size = size.tiny)
    else if lxEnable and lxShowChoch
        line.new(btmx, btmy, n, btmy, color = bearCss, style = line.style_dashed)
        label.new(int(math.avg(n, btmx)), btmy, 'CHoCH', color = color(na), style = label.style_label_up, textcolor = bearCss, size = size.tiny)

stopy = fixnan(stop)
sbtmy = fixnan(sbtm)

//Bullish BOS
//IDM
if low < sbtmy and not sbtm_crossed and os == 1 and sbtmy != btmy
    if lxEnable and lxShowIdm
        line.new(sbtmx, sbtmy, n, sbtmy, color = idmCss, style = line.style_dotted)
        label.new(int(math.avg(n, sbtmx)), sbtmy, 'IDM', color = color(na), style = label.style_label_up, textcolor = idmCss, size = size.tiny)
    sbtm_crossed := true

//BOS
if close > max and sbtm_crossed and os == 1
    if lxEnable and lxShowBos
        line.new(max_x1, max, n, max, color = bullCss)
        label.new(int(math.avg(n, max_x1)), max, 'BOS', color = color(na), style = label.style_label_down, textcolor = bullCss, size = size.tiny)
    sbtm_crossed := false

//Bearish BOS
//IDM
if high > stopy and not stop_crossed and os == 0 and stopy != topy
    if lxEnable and lxShowIdm
        line.new(stopx, stopy, n, stopy, color = color.gray, style = line.style_dotted)
        label.new(int(math.avg(n, stopx)), stopy, 'IDM', color = color(na), style = label.style_label_down, textcolor = color.gray, size = size.tiny)
    stop_crossed := true

//BOS
if close < min and stop_crossed and os == 0
    if lxEnable and lxShowBos
        line.new(min_x1, min, n, min, color = bearCss)
        label.new(int(math.avg(n, min_x1)), min, 'BOS', color = color(na), style = label.style_label_up, textcolor = bearCss, size = size.tiny)
    stop_crossed := false

//Sweeps
if high > max and close < max and os == 1 and n - max_x1 > 1 and lxEnable and showSweeps
    line.new(max_x1, max, n, max, color = sweepsCss, style = line.style_dotted)
    label.new(int(math.avg(n, max_x1)), max, 'x', color = color(na), style = label.style_label_down, textcolor = sweepsCss)

if low < min and close > min and os == 0 and n - min_x1 > 1 and lxEnable and showSweeps
    line.new(min_x1, min, n, min, color = sweepsCss, style = line.style_dotted)
    label.new(int(math.avg(n, min_x1)), min, 'x', color = color(na), style = label.style_label_up, textcolor = sweepsCss)

//Trailing max/min
max := math.max(high, max)
min := math.min(low, min)

if max > max[1]
    max_x1 := n
if min < min[1]
    min_x1 := n

//Extensions
var ext_choch = line.new(na, na, na, na, style = line.style_dashed)
var ext_bos   = line.new(na, na, na, na)
var ext_idm   = line.new(na, na, na, na, style = line.style_dotted, color = idmCss)

var ext_choch_lbl = label.new(na, na, 'CHoCH', color = color(na), size = size.tiny)
var ext_bos_lbl   = label.new(na, na, 'BOS', color = color(na), size = size.tiny)
var ext_idm_lbl   = label.new(na, na, 'IDM', color = color(na), size = size.tiny, textcolor = idmCss)

if barstate.islast and lxEnable
    if os == 1
        if lxShowChoch
            ext_choch.set_xy1(btmx, btmy), ext_choch.set_xy2(n, btmy), ext_choch.set_color(bearCss)
            ext_choch_lbl.set_xy(n, btmy), ext_choch_lbl.set_style(label.style_label_up), ext_choch_lbl.set_textcolor(bearCss)

        if lxShowBos
            ext_bos.set_xy1(max_x1, max), ext_bos.set_xy2(n, max), ext_bos.set_color(bullCss)
            ext_bos_lbl.set_xy(n, max), ext_bos_lbl.set_style(label.style_label_down), ext_bos_lbl.set_textcolor(bullCss)

        if not sbtm_crossed and lxShowIdm
            ext_idm.set_xy1(sbtmx, sbtmy), ext_idm.set_xy2(n + 15, sbtmy)
            ext_idm_lbl.set_xy(n + 15, sbtmy), ext_idm_lbl.set_style(label.style_label_up)
            ext_idm.set_color(idmCss), ext_idm_lbl.set_textcolor(idmCss)
        else
            ext_idm.set_color(na)
            ext_idm_lbl.set_textcolor(na)
    else
        if lxShowChoch
            ext_choch.set_xy1(topx, topy), ext_choch.set_xy2(n, topy), ext_choch.set_color(bullCss)
            ext_choch_lbl.set_xy(n, topy), ext_choch_lbl.set_style(label.style_label_down), ext_choch_lbl.set_textcolor(bullCss)

        if lxShowBos
            ext_bos.set_xy1(min_x1, min), ext_bos.set_xy2(n, min), ext_bos.set_color(bearCss)
            ext_bos_lbl.set_xy(n, min), ext_bos_lbl.set_style(label.style_label_up), ext_bos_lbl.set_textcolor(bearCss)

        if not stop_crossed and lxShowIdm
            ext_idm.set_xy1(stopx, stopy), ext_idm.set_xy2(n + 15, stopy)
            ext_idm_lbl.set_xy(n + 15, stopy), ext_idm_lbl.set_style(label.style_label_down)
            ext_idm.set_color(idmCss), ext_idm_lbl.set_textcolor(idmCss)
        else
            ext_idm.set_color(na)
            ext_idm_lbl.set_textcolor(na)

plot(lxEnable and showCircles ? lxTop : na, 'LX Swing High', color.new(bearCss, 50), 8, plot.style_circles, offset = -chochLen)
plot(lxEnable and showCircles ? btm   : na, 'LX Swing Low',  color.new(bullCss, 50), 8, plot.style_circles, offset = -chochLen)
//#endregion
