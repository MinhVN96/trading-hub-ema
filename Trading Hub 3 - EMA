    line ln = na
    label lbl = na
    x2 = time + (time - time[1]) * length
    colorText = trend ? color1 : color2
    if barstate.islast and condition
        [x, y] = switch
            txt == BOS_TEXT   => [trend ? lastHBar : lastLBar, trend ? lastH : lastL]
            txt == CHOCH_TEXT => [trend ? lastHBar : lastLBar, trend ? lastH : lastL]
